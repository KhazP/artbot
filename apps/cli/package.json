{
  "name": "artbot",
  "version": "0.3.1",
  "private": false,
  "description": "CLI for running ArtBot market research locally.",
  "author": "Alp Yalay <contact@alpyalay.org>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "artbot": "bin/artbot.cjs"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "preferGlobal": true,
  "keywords": [
    "art",
    "cli",
    "research",
    "valuation",
    "turkish-art"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhazP/artbot.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/KhazP/artbot#readme",
  "bugs": {
    "url": "https://github.com/KhazP/artbot/issues",
    "email": "contact@alpyalay.org"
  },
  "scripts": {
    "dev": "tsx src/bootstrap.ts",
    "build": "node ./scripts/build.mjs",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "verify:install": "node ./scripts/verify-install.mjs",
    "verify:build-copy": "node ./scripts/build.mjs"
  },
  "dependencies": {
    "@json-render/core": "latest",
    "@json-render/react": "latest",
    "@langchain/core": "^1.1.41",
    "@langchain/google": "^0.1.10",
    "@langchain/openai": "^1.4.4",
    "@clack/prompts": "^0.9.1",
    "@fastify/cors": "^11.0.1",
    "@mendable/firecrawl-js": "^1.29.3",
    "boxen": "^8.0.1",
    "cheerio": "^1.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "jimp": "^1.6.0",
    "langchain": "^1.3.4",
    "lucide-react": "latest",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@artbot/auth-manager": "workspace:*",
    "@artbot/browser-report": "workspace:*",
    "@artbot/extraction": "workspace:*",
    "@artbot/shared-types": "workspace:*",
    "@artbot/source-adapters": "workspace:*",
    "@artbot/source-registry": "workspace:*",
    "@artbot/storage": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/react": "^19.2.2",
    "esbuild": "^0.25.11"
  }
}

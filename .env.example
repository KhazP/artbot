NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_BASE_URL=http://localhost:4000
WORKER_POLL_INTERVAL_MS=3000
ARTBOT_API_KEY=
DATABASE_PATH=./data/artbot.db
RUNS_ROOT=./runs

MODEL_CHEAP_DEFAULT=gemini-3.1-flash-lite
MODEL_CHEAP_FALLBACK=gemini-2.5-flash-lite
STRUCTURED_LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio

FIRECRAWL_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
GEMINI_API_KEY=

ENABLE_LICENSED_INTEGRATIONS=false
DEFAULT_AUTH_PROFILE=
DEFAULT_LICENSED_INTEGRATIONS=
DEFAULT_ANALYSIS_MODE=comprehensive
DEFAULT_PRICE_NORMALIZATION=usd_dual

TRANSPORT_MAX_ATTEMPTS=3
TRANSPORT_REQUEST_TIMEOUT_MS=15000
TRANSPORT_CURL_FALLBACK=true

PIPELINE_MAX_CONCURRENCY=6
PIPELINE_DEGRADED_CONCURRENCY=3
PIPELINE_SUSPECTED_CONCURRENCY=1
PIPELINE_CANDIDATE_TIMEOUT_MS=45000
PIPELINE_HOST_BREAKER_THRESHOLD=3

DISCOVERY_ENABLED=true
DISCOVERY_MAX_CANDIDATES_PER_SOURCE=24
DISCOVERY_MAX_VARIANTS=3
DISCOVERY_DOMAIN_THROTTLE_PER_SOURCE=6
WEB_DISCOVERY_ENABLED=true
WEB_DISCOVERY_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
WEB_DISCOVERY_ALLOW_HOST_REGEX=
WEB_DISCOVERY_BLOCK_HOST_TOKENS=
WEB_DISCOVERY_PREFERRED_HOST_TOKENS=
WEB_DISCOVERY_LOW_QUALITY_HOST_TOKENS=
WEB_DISCOVERY_MIN_HOST_QUALITY_SCORE=0.12
WEB_DISCOVERY_MAX_DOMAINS_PER_RUN=60
WEB_DISCOVERY_MAX_URLS_PER_DOMAIN=12
WEB_DISCOVERY_MAX_TOTAL_CANDIDATES=1200
EVIDENCE_TRACE_MODE=selective

FX_PROVIDER=ecb
FX_TRY_FALLBACK_PROVIDER=tcmb
USD_INFLATION_PROVIDER=us_cpi
USD_INFLATION_BASE_YEAR=2026
